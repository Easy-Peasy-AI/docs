{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Easy-Peasy.AI",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Text Generation",
            "pages": [
              "api-reference/endpoint/generate"
            ]
          },
          {
            "group": "Image Generation",
            "pages": [
              "api-reference/endpoint/generate-image"
            ]
          },
          {
            "group": "Transcription",
            "pages": [
              "api-reference/endpoint/create-transcription"
            ]
          },
          {
            "group": "Text-to-Speech",
            "pages": [
              "api-reference/endpoint/get-tts-config",
              "api-reference/endpoint/get-tts-voices",
              "api-reference/endpoint/generate-tts"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Templates",
          "href": "https://easy-peasy.ai/presets",
          "icon": "wand-magic-sparkles"
        },
        {
          "anchor": "Get API Key",
          "href": "https://easy-peasy.ai/settings/api",
          "icon": "key"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@easy-peasy.ai"
      }
