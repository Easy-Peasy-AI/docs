  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/easy_peasy_ai",
      "website": "https://easy-peasy.ai"
    }
  }
